# ==============================================================================
# Model Regression Detection System - Environment Variables
# ==============================================================================

# -- Core Settings --
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=text  # text or json

# -- LLM Providers --
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# -- Database --
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mrds_db

# -- API Settings --
API_HOST=0.0.0.0
API_PORT=8000
